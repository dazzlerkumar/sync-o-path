{
  "name": "sync-o-path",
  "version": "1.0.0",
  "type": "module",
  "description": "Sync-o-path is an AI-powered agent designed to automate the administrative overhead of software development. It listens to Discord voice meetings, monitors chat threads, and uses Gemini 1.5 Flash to instantly generate structured tasks, bug reports, and meeting summaries directly in our self-hosted YouTrack instance.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "ts-node src/index.ts",
    "dev:no-logs": "NODE_OPTIONS='--loader ts-node/esm --no-warnings' ts-node src/index.ts",
    "test": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dazzlerkumar/sync-o-path.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/dazzlerkumar/sync-o-path/issues"
  },
  "homepage": "https://github.com/dazzlerkumar/sync-o-path#readme",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.13.6",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@shoginn/discordjs-mock": "^1.0.11",
    "@types/node": "^25.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
